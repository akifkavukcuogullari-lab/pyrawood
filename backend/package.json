{
  "name": "pyra-wood-backend",
  "version": "1.0.0",
  "description": "Pyra Wood e-commerce backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/migrations/run.ts",
    "seed": "tsx src/seeds/run.ts",
    "test": "jest --passWithNoTests",
    "test:unit": "jest --testPathPatterns=unit --passWithNoTests",
    "test:integration": "jest --testPathPatterns=integration --passWithNoTests",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "bcrypt": "^5.1",
    "cors": "^2.8",
    "dotenv": "^16",
    "express": "^4.18",
    "helmet": "^7",
    "jsonwebtoken": "^9",
    "morgan": "^1.10",
    "multer": "^1.4",
    "pg": "^8.11",
    "stripe": "^14",
    "uuid": "^9",
    "zod": "^3.22"
  },
  "devDependencies": {
    "@types/bcrypt": "^5",
    "@types/cors": "^2",
    "@types/express": "^4",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9",
    "@types/morgan": "^1",
    "@types/multer": "^1",
    "@types/node": "^20",
    "@types/pg": "^8",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4",
    "typescript": "^5.3"
  }
}
